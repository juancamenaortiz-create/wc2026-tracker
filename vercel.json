{
  "functions": {
    "api/preview.js":   { "maxDuration": 25 },
    "api/team.js":      { "maxDuration": 25 },
    "api/subscribe.js": { "maxDuration": 10 },
    "api/cron.js":      { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
