{
  "functions": {
    "api/scores.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 25
    },
    "api/preview.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 25
    },
    "api/team.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 25
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}